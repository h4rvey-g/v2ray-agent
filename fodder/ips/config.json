        }
      },
      "type": "vless",
      "uuid": "a4e080df",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp"
    },
    {
      "server": "198.211.6.60",
      "server_port": 1562,
      "tag": "nerd",
      "tls": {
        "enabled": true,
        "server_name": "addons.mozilla.org",
        "utls": {
          "enabled": true,
          "fingerprint": "firefox"
        }
      },
      "type": "vless",
      "uuid": "7c72e318",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp"
    },
    {
      "server": "bart.howies.live",
      "server_port": 20495,
      "tag": "bart_hysteria",
      "tls": {
        "enabled": true,
