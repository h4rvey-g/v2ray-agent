      "down_mbps": 100,
      "up_mbps": 50
    },
    {
      "server": "homer.howies.live",
      "server_port": 10000,
      "tag": "nerd_hysteria",
      "tls": {
        "enabled": true,
        "server_name": "homer.howies.live",
        "alpn": ["h3"]
