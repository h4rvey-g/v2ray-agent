{
  "dns": {
    "servers": [
      {
        "tag": "dns_proxy",
        "address": "1.1.1.1",
        "address_resolver": "dns_direct",
        "strategy": "ipv4_only",
        "detour": "urltest"
      },
      {
        "tag": "dns_direct",
        "address": "223.5.5.5",
        "strategy": "ipv4_only",
        "detour": "direct"
      },
      {
        "tag": "dns_block",
        "address": "rcode://success"
      }
    ],
    "rules": [
      {
        "geosite": ["category-ads-all"],
        "server": "dns_block",
        "disable_cache": true
      },
      {
        "geosite": ["geolocation-!cn"],
        "server": "dns_proxy"
      },
      {
        "geosite": ["cn", "private"],
        "server": "dns_direct"
      },
      {
        "outbound": ["any"],
        "server": "dns_direct"
      }
    ]
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": "",
      "store_selected": true
    }
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "inet4_address": "172.19.0.1/30",
      "auto_route": true,
      "strict_route": true,
      "stack": "gvisor",
      "sniff": true
    }
  ],
  "log": {},
  "outbounds": [
    {
      "tag": "select",
      "type": "selector",
      "default": "bart",
      "outbounds": ["bart", "nerd", "bart_hysteria", "nerd_hysteria"]
    },
    {
      "tag": "urltest",
      "type": "urltest",
      "interval": "5m",
      "outbounds": ["bart", "nerd", "bart_hysteria", "nerd_hysteria"]
    },
    {
      "server": "156.251.130.60",
      "server_port": 11775,
      "tag": "bart",
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
