      },
      "type": "vless",
      "uuid": "7c72e318-0386-46f8-bfef-faa1956cf101",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp"
    },
    {
      "server": "bart.howies.live",
      "server_port": 20495,
      "tag": "bart_hysteria",
      "tls": {
        "enabled": true,
        "server_name": "bart.howies.live",
